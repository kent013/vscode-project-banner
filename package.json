{
  "name": "vscode-project-banner",
  "displayName": "Project Banner",
  "description": "Display the current project name as a large splash on window focus, plus a colored status bar item, to disambiguate parallel VSCode windows.",
  "version": "0.0.3",
  "publisher": "ishitoya",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/kent013/vscode-project-banner.git"
  },
  "bugs": {
    "url": "https://github.com/kent013/vscode-project-banner/issues"
  },
  "homepage": "https://github.com/kent013/vscode-project-banner#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "ui"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "projectBanner.show",
        "title": "Project Banner: Show splash now"
      }
    ],
    "configuration": {
      "title": "Project Banner",
      "properties": {
        "projectBanner.splash.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show a splash with the project name when this window gains focus."
        },
        "projectBanner.splash.durationMs": {
          "type": "number",
          "default": 3000,
          "minimum": 100,
          "maximum": 10000,
          "description": "How long (ms) the splash stays open before auto-closing."
        },
        "projectBanner.splash.fontSize": {
          "type": "number",
          "default": 200,
          "minimum": 24,
          "maximum": 600,
          "description": "Font size (px) of the project name in the splash."
        },
        "projectBanner.splash.minIntervalMs": {
          "type": "number",
          "default": 3000,
          "minimum": 0,
          "maximum": 600000,
          "description": "Minimum time (ms) between two splash displays. Prevents flicker on rapid focus toggling."
        },
        "projectBanner.statusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the project banner item in the status bar."
        },
        "projectBanner.statusBar.useWarningBackground": {
          "type": "boolean",
          "default": false,
          "description": "Apply the editor's warning background color to the status bar item for stronger emphasis."
        },
        "projectBanner.text": {
          "type": "string",
          "default": "",
          "description": "Override the displayed text. Empty means use the workspace name."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "vscode:prepublish": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "pretest": "tsc -p ./",
    "test": "mocha --recursive \"out/test/**/*.test.js\"",
    "dev": "npm run build && code --extensionDevelopmentPath=\"$PWD\"",
    "package:vsix": "npm run build && npx --yes @vscode/vsce package --skip-license --out vscode-project-banner.vsix",
    "dist": "npm run build && npx --yes @vscode/vsce package --skip-license",
    "install:local": "npm run package:vsix && code --install-extension ./vscode-project-banner.vsix --force",
    "uninstall:local": "code --uninstall-extension ishitoya.vscode-project-banner"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "mocha": "^10.3.0",
    "typescript": "^5.4.0"
  }
}
